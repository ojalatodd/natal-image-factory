# ============================================================
# Natal Image Factory — environment configuration
# Copy to .env and fill in. NEVER commit the real .env.
# ============================================================

# ---- App ----
APP_ENV=development            # development | production
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=10080
# First-run bootstrap user (created if no users exist)
BOOTSTRAP_USER_EMAIL=daniel@example.com
BOOTSTRAP_USER_PASSWORD=change-me

# ---- Database ----
# Local default is SQLite on a Docker volume. Swap to postgresql:// for managed DB later.
DATABASE_URL=sqlite:////data/app.db

# ---- Redis (Celery broker + progress) ----
REDIS_URL=redis://redis:6379/0

# ---- AI providers (Whisper + GPT/Claude/Gemini/DeepSeek + optional DALL-E) ----
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# ---- DigitalOcean Spaces (S3-compatible object storage) ----
# For LOCAL dev you can run MinIO instead (see docker-compose.yml). Defaults target the local MinIO.
SPACES_ENDPOINT_URL=http://minio:9000
# Public-facing endpoint for presigned URLs (falls back to SPACES_ENDPOINT_URL if not set)
SPACES_PRESIGN_ENDPOINT_URL=http://localhost:9000
SPACES_REGION=us-east-1
SPACES_BUCKET=natal-media
SPACES_KEY=minioadmin
SPACES_SECRET=minioadmin
# Public base URL used to build download links (CDN in prod, MinIO in dev)
SPACES_PUBLIC_URL=http://localhost:9000/natal-media

# ---- Video / stock source API keys (optional; archive.org/NARA/NASA/LoC need none) ----
PEXELS_API_KEY=
PIXABAY_API_KEY=
UNSPLASH_ACCESS_KEY=
SMITHSONIAN_API_KEY=

# ---- Frontend ----
VITE_API_BASE_URL=/api
